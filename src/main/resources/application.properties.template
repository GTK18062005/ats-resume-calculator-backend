# ============================================
# SPRING BOOT APPLICATION PROPERTIES
# ATS Resume Calculator - Template
# ============================================
# Copy this file to application.properties
# and fill in your values
# DO NOT COMMIT application.properties to Git!

# ---------- Application ----------
spring.application.name=ats-resume-calculator

# ---------- Database (MySQL) ----------
spring.datasource.url=${DATABASE_URL}
spring.datasource.username=${DATABASE_USERNAME}
spring.datasource.password=${DATABASE_PASSWORD}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# ---------- JPA/Hibernate ----------
spring.jpa.hibernate.ddl-auto=update
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.show-sql=true

# ---------- File Upload ----------
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# ---------- AI Providers ----------
# Groq API
ai.grok.api-key=${GROQ_API_KEY}
ai.grok.url=https://api.groq.com/openai/v1/chat/completions
ai.grok.model=llama-3.3-70b-versatile

# Google Gemini
ai.gemini.api-key=${GEMINI_API_KEY}
ai.gemini.url=https://generativelanguage.googleapis.com/v1beta/models
ai.gemini.model=gemini-3.5-flash

# OpenRouter
ai.openrouter.api-key=${OPENROUTER_API_KEY}
ai.openrouter.url=https://openrouter.ai/api/v1/chat/completions
ai.openrouter.model=openai/gpt-4o-mini

# ---------- Server ----------
server.port=${PORT:8080}
server.error.include-message=always
server.error.include-binding-errors=always

# ---------- Logging ----------
logging.level.com.example=INFO
logging.level.org.springframework.web=INFO
logging.level.org.hibernate=INFO
logging.pattern.console=%d{yyyy-MM-dd HH:mm:ss} - %msg%n


